{
  "name": "embl-server",
  "version": "1.0.0",
  "description": "A Model Context Protocol server for accessing EMBL-EBI bioinformatics APIs including InterPro, Pfam, UniProt features, and taxonomy",
  "main": "build/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "start": "node build/index.js",
    "dev": "tsc --watch"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "embl",
    "ebi",
    "interpro",
    "pfam",
    "uniprot",
    "taxonomy",
    "bioinformatics",
    "protein-domains",
    "protein-families"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.9.3"
  },
  "bin": {
    "embl-server": "./build/index.js"
  }
}
